        "",
        "  def teacher_assigned(student)",
        "    @student = student",
        "    @teacher = student.teacher",
        "",
        "    mail(",
        "      to: @student.email,",
        "      subject: \"Teacher Assigned\"",
        "    )",
        "  end",
        "",
        "",
        "  def marks_published(student)",
        "    @student = student",
        "",
