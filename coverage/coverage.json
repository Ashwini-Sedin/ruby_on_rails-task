        "",
        "class StudentMailer < ApplicationMailer",
        "  default from: \"kannanash31@gmail.com\"",
        "",
        "  def welcome_email(student)",
        "    @student = student",
        "    @teacher = student.teacher",
        "",
        "    mail(",
        "      to: @student.email,",
        "      subject: \"Welcome to ABC Academy\"",
        "    )",
