{
	"info": {
		"_postman_id": "a98a0f9a-14d2-4cfb-b8bc-d9eeefc842b1",
		"name": "Student Management RESTful API Collection (JWT Secured)",
		"description": "Postman collection for RESTful API testing of the Student Management application. Securely authenticated via JWT. Includes authentication, CRUD, filtering, and negative scenario tests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Sign In (Get JWT Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Automatically save JWT token from headers to a collection variable",
									"var authHeader = pm.response.headers.get('Authorization');",
									"if (authHeader) {",
									"    var token = authHeader.replace('Bearer ', '');",
									"    pm.collectionVariables.set('jwt_token', token);",
									"    console.log('JWT Token saved successfully: ' + token);",
									"}"
								],
								"type": "javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user\": {\n    \"email\": \"teacher@gmail.com\",\n    \"password\": \"password\"\n  }\n}"
						},
						"url": {
							"raw": "http://localhost:3000/users/sign_in.json",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3000",
							"path": [
								"users",
								"sign_in.json"
							]
						},
						"description": "Logs in the user and returns a JWT in the 'Authorization' header. A post-request script automatically saves this token as a collection variable 'jwt_token' for use in other requests."
					},
					"response": []
				}
			]
		},
