
<header class="header">
  <div class="header-container">
    <h1><%= link_to "Student Management", root_path, class: "logo" %></h1>

    <nav class="navbar">
      <div class="nav-links">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", dashboard_path %>
          <%= link_to "Students List", students_path %>
          <%= link_to "Add Student", new_student_path, data: { turbo_frame: "new_student_form" } %>

          <% if current_user.admin? %>
            <%= link_to "Teachers", users_path(role: "teacher") %>
          <% end %>
        <% end %>
      </div>

      <div class="user-actions">
        <% if user_signed_in? %>
          <span class="user-welcome">
            Welcome, <strong><%= current_user.name %></strong> (<%= current_user.role %>)
          </span>
          <%= button_to "Logout",
                destroy_user_session_path,
                method: :delete,
                class: "btn-logout" %>
        <% else %>
          <%= link_to "Login", new_user_session_path, class: "nav-link" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "btn-signup" %>
        <% end %>
      </div>
    </nav>
  </div>
</header>