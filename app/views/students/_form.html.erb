<div class="form-container" data-controller="student-form">
  <%= form_with model: @student do |f| %>
    <% if @student.errors.any? %>
      <div class="error-box" style="background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; padding: 15px; border-radius: 4px; margin-bottom: 20px;">
        <ul style="margin: 0; padding-left: 20px;">
          <% @student.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :name, style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.text_field :name, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;",
            data: {
              student_form_target: "name",
              action: "input->student-form#updateCounter input->student-form#validate"
            } %>
      <div style="font-size: 0.85em; color: #64748b; margin-top: 4px;">
        Name length: <span data-student-form-target="counter">0</span> characters
      </div>
    </div>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :email, style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.email_field :email, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;",
            data: {
              student_form_target: "required",
              action: "input->student-form#validate"
            } %>
    </div>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :age, style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.number_field :age, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;",
            data: {
              student_form_target: "required",
              action: "input->student-form#validate"
            } %>
    </div>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :city, style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.text_field :city, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;",
            data: {
              student_form_target: "required",
              action: "input->student-form#validate"
            } %>
    </div>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :course, style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.select :course, ["Ruby", "Rails", "React", "Java"], {}, {
            style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;",
            data: {
              student_form_target: "required",
              action: "change->student-form#validate"
            }
          } %>
    </div>

    <% if current_user.admin? %>
      <div class="form-group" style="margin-bottom: 15px;">
        <%= f.label :teacher_id, "Assign Teacher", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
        <%= f.collection_select :teacher_id,
            User.teacher,
            :id,
            :name,
            { prompt: "Select Teacher" },
            {
              style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;",
              data: {
                student_form_target: "required",
                action: "change->student-form#validate"
              }
            } %>
      </div>
    <% end %>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :marks, style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.number_field :marks, style: "width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" %>
    </div>

    <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

    <h3>Profile Photo</h3>

    <% if @student.profile_photo.attached? && @student.profile_photo.persisted? %>
      <div class="profile-photo" style="margin-bottom: 15px; padding: 10px; border: 1px solid #eee; border-radius: 4px; width: fit-content;">
        <%= image_tag @student.profile_photo, style: "max-width: 200px; display: block; margin-bottom: 10px; border-radius: 4px;" %>
        <%= link_to "Delete Photo",
            remove_profile_photo_student_path(@student),
            data: {
              turbo_method: :delete,
              turbo_confirm: "Delete profile photo?"
            },
            class: "btn btn-danger" %>
      </div>
    <% end %>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :profile_photo, "Upload/Replace Profile Photo", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.file_field :profile_photo %>
    </div>

    <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

    <h3>Documents</h3>

    <div class="form-group" style="margin-bottom: 15px;">
      <%= f.label :documents, "Upload Documents", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
      <%= f.file_field :documents, multiple: true %>
    </div>

    <% if @student.documents.attached? %>
      <table class="documents-table" style="width: 100%; border-collapse: collapse; margin-bottom: 20px; text-align: left;">
        <thead>
          <tr style="border-bottom: 1px solid #ccc; background-color: #f9f9f9;">
            <th style="padding: 10px; border: 1px solid #ddd;">Document Name</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 120px;">Download</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 100px;">Delete</th>
          </tr>
        </thead>
        <tbody>
          <% @student.documents.each do |document| %>
            <% if document.persisted? %>
              <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px; border: 1px solid #ddd;"><%= document.filename %></td>
                <td style="padding: 10px; border: 1px solid #ddd;">
                  <%= link_to "Download",
                      rails_blob_path(document, disposition: "attachment"),
                      class: "btn btn-success" %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd;">
                  <%= link_to "Delete",
                      remove_document_student_path(@student, attachment_id: document.id),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "Delete this document?"
                      },
                      class: "btn btn-danger" %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <br>

    <%= f.submit class: "btn btn-primary", data: { student_form_target: "submit" } %>
    
  <% end %>
</div>