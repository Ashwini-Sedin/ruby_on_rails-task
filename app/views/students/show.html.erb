<div class="card" style="padding: 20px; border: 1px solid #ddd; border-radius: 8px; max-width: 600px; margin: 20px auto;">

<h2>Student Details</h2>

<% if @student.profile_photo.attached? %>
  <div class="profile-photo" style="margin-bottom: 20px;">
    <%= image_tag @student.profile_photo, style: "max-width: 150px; border-radius: 50%; border: 3px solid #ccc; display: block;" %>
  </div>
<% end %>

<p><strong>Name:</strong> <%= @student.name %></p>
<p><strong>Email:</strong> <%= @student.email %></p>
<p><strong>Age:</strong> <%= @student.age %></p>
<p><strong>Course:</strong> <%= @student.course %></p>
<p><strong>City:</strong> <%= @student.city %></p>
<p><strong>Marks:</strong> <%= @student.marks %></p>

<p>
  <strong>Result:</strong>

  <% if @student.result == "pass" %>
    <span style="color:green;font-weight:bold;">
      Pass
    </span>
  <% else %>
    <span style="color:red;font-weight:bold;">
      Fail
    </span>
  <% end %>
</p>

<% if @student.documents.attached? %>
  <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">
  <h3>Documents</h3>
  <ul class="documents-list" style="padding-left: 20px;">
    <% @student.documents.each do |document| %>
      <li style="margin-bottom: 10px;">
        <%= document.filename %> - 
        <%= link_to "Download",
            rails_blob_path(document, disposition: "attachment"),
            style: "color: #007bff; text-decoration: none;" %>
      </li>
    <% end %>
  </ul>
<% end %>

<div style="margin-top: 20px;">
  <%= link_to "Edit", edit_student_path(@student), class: "btn" %> |
  <%= link_to "Back to Students", students_path, class: "btn" %>
</div>

</div>