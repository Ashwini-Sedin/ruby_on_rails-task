<h2>Students List</h2>

<div class="search-filter">

  <%= form_with url: students_path,
                method: :get,
                data: { turbo_frame: "students_table" } do %>

    <%= text_field_tag :search,
        params[:search],
        placeholder: "Search students...",
        oninput: "this.form.requestSubmit()" %>


    <%= select_tag :course,
        options_for_select(
          ["Ruby", "Rails", "React", "Java"],
          params[:course]
        ),
        include_blank: "All courses" %>


    <%= submit_tag "Filter" %>

  <% end %>

</div>


<br>


<div id="student_count">
  Total Students: <%= @students.count %>
</div>


<%= turbo_frame_tag "new_student_form" %>
<%= turbo_frame_tag "edit_student" %>


<%= turbo_frame_tag "students_table" do %>
  <%= render "students_table" %>
<% end %>