FROM ruby:4.0.3

# Install required packages
RUN apt-get update -qq && apt-get install -y \
    build-essential \
    git \
    nodejs \
    sqlite3 \
    libsqlite3-dev

WORKDIR /rails

# Install gems
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy application
COPY . .

EXPOSE 3000

CMD ["bash", "-c", "bundle exec rails db:prepare && bundle exec rails server -b 0.0.0.0 -p 3000"]